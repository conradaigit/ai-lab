{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-lab.local/schemas/workspace/codex_handoff.v1.json",
  "title": "Codex Close Session Handoff v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "generated_at",
    "project_slug",
    "project_type",
    "canonical_assertion",
    "repo_close_checks",
    "repo_state",
    "snapshot",
    "session_handoff",
    "close_workspace_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "contract_version": {
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project_slug": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "project_type": {
      "const": "repo_backed"
    },
    "canonical_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_state",
        "continuity_pm_state"
      ],
      "properties": {
        "implementation_state": {
          "const": "repo"
        },
        "continuity_pm_state": {
          "const": "drive"
        }
      }
    },
    "repo_close_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_memory_updated",
        "commit_created",
        "push_completed",
        "snapshot_exported"
      ],
      "properties": {
        "repo_memory_updated": {
          "const": true
        },
        "commit_created": {
          "const": true
        },
        "push_completed": {
          "const": true
        },
        "snapshot_exported": {
          "const": true
        }
      }
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "head_commit",
        "dirty_clean"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "head_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "dirty_clean": {
          "enum": [
            "dirty",
            "clean"
          ]
        },
        "upstream": {
          "type": "string"
        },
        "commit_message": {
          "type": "string"
        }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "snapshot_generated_at",
        "branch",
        "head_commit",
        "dirty_clean",
        "current_focus",
        "last_completed_work",
        "next_1_3_actions",
        "task_summary",
        "active_plan_summary",
        "progress_summary",
        "latest_session_summary"
      ],
      "properties": {
        "project": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "snapshot_generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "head_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "dirty_clean": {
          "enum": [
            "dirty",
            "clean"
          ]
        },
        "current_focus": {
          "type": "string"
        },
        "last_completed_work": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_1_3_actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        },
        "task_summary": {
          "type": "string"
        },
        "active_plan_summary": {
          "type": "string"
        },
        "progress_summary": {
          "type": "string"
        },
        "latest_session_summary": {
          "type": "string"
        }
      }
    },
    "session_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "completed",
        "decisions",
        "issues",
        "next_actions"
      ],
      "properties": {
        "objective": {
          "type": "string"
        },
        "completed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "close_workspace_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "write_reasoning_note",
        "write_timeline_event",
        "update_profile_timestamps_status",
        "milestone_updates_require_explicit_confirmation"
      ],
      "properties": {
        "write_reasoning_note": {
          "const": true
        },
        "write_timeline_event": {
          "const": true
        },
        "update_profile_timestamps_status": {
          "const": true
        },
        "milestone_updates_require_explicit_confirmation": {
          "const": true
        }
      }
    }
  }
}
