{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Memory Object Base",
  "description": "Base schema for machine-readable memory objects stored under memory/objects/<type>/<id>.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "type",
    "project",
    "created_at",
    "updated_at",
    "status",
    "summary",
    "body",
    "data",
    "tags",
    "links",
    "source_refs",
    "confidence",
    "supersedes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "type": {
      "type": "string",
      "enum": [
        "decision",
        "task",
        "lesson",
        "artifact",
        "entity",
        "relation"
      ]
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "superseded",
        "archived",
        "failed",
        "draft"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string"
    },
    "data": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "integer",
        "boolean",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "relation"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "relation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
